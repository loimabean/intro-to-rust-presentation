{
  "name": "warm-burnout-light",
  "displayName": "Warm Burnout Light",
  "type": "light",
  "fg": "#3a3630",
  "bg": "#F5EDE0",
  "colors": {
    "editor.background": "#F5EDE0",
    "editor.foreground": "#3a3630",
    "editor.selectionBackground": "#8aa8b860",
    "editor.lineHighlightBackground": "#00000014",
    "editorCursor.foreground": "#8a6600",
    "terminal.background": "#EDE6DA",
    "terminal.foreground": "#3a3630",
    "terminal.ansiBlack": "#3a3630",
    "terminal.ansiRed": "#b82820",
    "terminal.ansiGreen": "#2d6a14",
    "terminal.ansiYellow": "#8a6000",
    "terminal.ansiBlue": "#2060a0",
    "terminal.ansiMagenta": "#8a3090",
    "terminal.ansiCyan": "#146858",
    "terminal.ansiWhite": "#c0b8aa",
    "terminal.ansiBrightBlack": "#686868",
    "terminal.ansiBrightRed": "#c83028",
    "terminal.ansiBrightGreen": "#3a7a20",
    "terminal.ansiBrightYellow": "#9a7008",
    "terminal.ansiBrightBlue": "#2870b0",
    "terminal.ansiBrightMagenta": "#9a38a0",
    "terminal.ansiBrightCyan": "#208870",
    "terminal.ansiBrightWhite": "#FAF6F0"
  },
  "tokenColors": [
    {
      "settings": {
        "background": "#F5EDE0",
        "foreground": "#3a3630"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#544c40"
      }
    },
    {
      "name": "String",
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#4d5c1a"
      }
    },
    {
      "name": "Regular Expressions and Escape Characters",
      "scope": ["string.regexp", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#286a48"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#7e4060"
      }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#7e4060"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.parameter.function-call"],
      "settings": {
        "foreground": "#3a3630"
      }
    },
    {
      "name": "Member Variable",
      "scope": ["variable.member"],
      "settings": {
        "foreground": "#883850"
      }
    },
    {
      "name": "Language variable",
      "scope": ["variable.language"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#8e4632"
      }
    },
    {
      "name": "Storage",
      "scope": ["storage"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#924800"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#924800"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#8f4418"
      }
    },
    {
      "name": "Separators like ; or ,",
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#3a3630d9"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation.section"],
      "settings": {
        "foreground": "#3a3630"
      }
    },
    {
      "name": "Accessor",
      "scope": ["punctuation.accessor"],
      "settings": {
        "foreground": "#8f4418"
      }
    },
    {
      "name": "JavaScript/TypeScript interpolation punctuation",
      "scope": ["punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#924800"
      }
    },
    {
      "name": "Ruby interpolation punctuation",
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#924800"
      }
    },
    {
      "name": "Interpolation text",
      "scope": ["meta.embedded"],
      "settings": {
        "foreground": "#3a3630"
      }
    },
    {
      "name": "Types fixes",
      "scope": [
        "source.java storage.type",
        "source.haskell storage.type",
        "source.c storage.type"
      ],
      "settings": {
        "foreground": "#285464"
      }
    },
    {
      "name": "Inherited class type",
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#285464"
      }
    },
    {
      "name": "Lambda arrow",
      "scope": ["storage.type.function"],
      "settings": {
        "foreground": "#924800"
      }
    },
    {
      "name": "Java primitive variable types",
      "scope": ["source.java storage.type.primitive"],
      "settings": {
        "foreground": "#285464"
      }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#855700"
      }
    },
    {
      "name": "Function arguments",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": {
        "foreground": "#7e4060"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "variable.function",
        "variable.annotation",
        "meta.function-call.generic",
        "support.function.go"
      ],
      "settings": {
        "foreground": "#855700"
      }
    },
    {
      "name": "Library function",
      "scope": ["support.function", "support.macro"],
      "settings": {
        "foreground": "#883850"
      }
    },
    {
      "name": "Imports and packages",
      "scope": ["entity.name.import", "entity.name.package"],
      "settings": {
        "foreground": "#4d5c1a"
      }
    },
    {
      "name": "Type name",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.union",
        "entity.name.trait"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#285464"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#8e4632"
      }
    },
    {
      "name": "JSX Component",
      "scope": ["support.class.component"],
      "settings": {
        "foreground": "#285464"
      }
    },
    {
      "name": "Tag start/end",
      "scope": [
        "punctuation.definition.tag.end",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8e4632"
      }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#855700"
      }
    },
    {
      "name": "CSS pseudo-class",
      "scope": ["entity.other.attribute-name.pseudo-class"],
      "settings": {
        "foreground": "#286a48"
      }
    },
    {
      "name": "Library constant",
      "scope": ["support.constant"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#8f4418"
      }
    },
    {
      "name": "Library class/type",
      "scope": ["support.type", "support.class", "source.go storage.type"],
      "settings": {
        "foreground": "#285464"
      }
    },
    {
      "name": "Decorators/annotation",
      "scope": [
        "meta.decorator variable.other",
        "meta.decorator punctuation.decorator",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7a5a1c"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#b03434"
      }
    },
    {
      "name": "diff.header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#6a5050"
      }
    },
    {
      "name": "Ruby class methods",
      "scope": ["source.ruby variable.other.readwrite"],
      "settings": {
        "foreground": "#855700"
      }
    },
    {
      "name": "CSS tag names",
      "scope": [
        "source.css entity.name.tag",
        "source.sass entity.name.tag",
        "source.scss entity.name.tag",
        "source.less entity.name.tag",
        "source.stylus entity.name.tag"
      ],
      "settings": {
        "foreground": "#74501c"
      }
    },
    {
      "name": "CSS browser prefix",
      "scope": [
        "source.css support.type",
        "source.sass support.type",
        "source.scss support.type",
        "source.less support.type",
        "source.stylus support.type"
      ],
      "settings": {
        "foreground": "#544c40"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#74501c"
      }
    },
    {
      "name": "Search Results Numbers",
      "scope": ["constant.numeric.line-number.find-in-files - match"],
      "settings": {
        "foreground": "#544c40"
      }
    },
    {
      "name": "Search Results Match Numbers",
      "scope": ["constant.numeric.line-number.match"],
      "settings": {
        "foreground": "#924800"
      }
    },
    {
      "name": "Search Results Lines",
      "scope": ["entity.name.filename.find-in-files"],
      "settings": {
        "foreground": "#4d5c1a"
      }
    },
    {
      "scope": ["message.error"],
      "settings": {
        "foreground": "#b03434"
      }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4d5c1a"
      }
    },
    {
      "name": "Markup links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": {
        "foreground": "#8e4632"
      }
    },
    {
      "name": "Markup Italic/Emphasis",
      "scope": ["markup.italic", "emphasis"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#883850"
      }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#883850"
      }
    },
    {
      "name": "Markup Underline",
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup Bold/italic",
      "scope": ["markup.italic markup.bold", "markup.bold markup.italic"],
      "settings": {
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Markup Code",
      "scope": ["markup.raw"],
      "settings": {
        "background": "#3a363005"
      }
    },
    {
      "name": "Markup Code Inline",
      "scope": ["markup.raw.inline"],
      "settings": {
        "background": "#3a36300f"
      }
    },
    {
      "name": "Markdown Separator",
      "scope": ["meta.separator"],
      "settings": {
        "fontStyle": "bold",
        "background": "#3a36300f",
        "foreground": "#544c40"
      }
    },
    {
      "name": "Markup Blockquote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#286a48",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup List Bullet",
      "scope": ["markup.list punctuation.definition.list.begin"],
      "settings": {
        "foreground": "#855700"
      }
    },
    {
      "name": "Markup added",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#226414"
      }
    },
    {
      "name": "Markup modified",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#8a6000"
      }
    },
    {
      "name": "Markup removed",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#c43040"
      }
    },
    {
      "name": "Markup Strike",
      "scope": ["markup.strike"],
      "settings": {
        "foreground": "#7a5a1c"
      }
    },
    {
      "name": "Markup strong",
      "scope": ["markup.strong"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Table",
      "scope": ["markup.table"],
      "settings": {
        "background": "#3a36300f",
        "foreground": "#74501c"
      }
    },
    {
      "name": "Markup Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw"],
      "settings": {
        "foreground": "#8f4418"
      }
    },
    {
      "name": "Markdown - Line Break",
      "scope": ["text.html.markdown meta.dummy.line-break"],
      "settings": {
        "background": "#544c40",
        "foreground": "#544c40"
      }
    },
    {
      "name": "Markdown - Raw Block Fenced",
      "scope": ["punctuation.definition.markdown"],
      "settings": {
        "background": "#3a3630",
        "foreground": "#544c40"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": {
      "foreground": "#285464",
      "italic": true
    },
    "class.defaultLibrary": {
      "foreground": "#285464",
      "italic": true
    },
    "enum": {
      "foreground": "#285464",
      "italic": true
    },
    "enum.defaultLibrary": {
      "foreground": "#285464",
      "italic": true
    },
    "interface": {
      "foreground": "#285464",
      "italic": true
    },
    "interface.defaultLibrary": {
      "foreground": "#285464",
      "italic": true
    },
    "struct": {
      "foreground": "#285464",
      "italic": true
    },
    "struct.defaultLibrary": {
      "foreground": "#285464",
      "italic": true
    },
    "type": {
      "foreground": "#285464",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#285464",
      "italic": true
    },
    "enumMember": "#286a48",
    "event": "#8f4418",
    "function": "#855700",
    "method": "#855700",
    "macro": "#7a5a1c",
    "comment": {
      "foreground": "#544c40",
      "italic": true
    },
    "string": "#4d5c1a",
    "keyword": {
      "foreground": "#924800",
      "bold": true
    },
    "number": "#7e4060",
    "regexp": "#286a48",
    "operator": "#8f4418"
  }
}
